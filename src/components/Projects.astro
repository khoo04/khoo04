---
import { siteConfig } from "../config";
const base = import.meta.env.BASE_URL; // This will be "/khoo04"
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-12">
              {siteConfig.projects.map((project, index) => (
                <div class="group relative p-4 sm:p-6 md:p-8 bg-gray-50 rounded-xl sm:rounded-2xl border border-gray-200 transition-all duration-300 hover:bg-white hover:shadow-xl hover:border-gray-300">
                  <div class="flex flex-col xl:flex-row gap-8">
                   {/* Project Image */}
                    {project.image && (
                      <div class="xl:w-1/3 flex items-center justify-center overflow-hidden rounded-lg border border-gray-200 bg-white p-2">
                        <img 
                          src={project.image.startsWith('http') ? project.image : `${base}${project.image}`}
                          alt={`${project.name} screenshot`}
                          class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
                        />
                      </div>
                    )}

                    <div class="flex-1 space-y-4">
                      <div class="flex justify-between items-start">
                        <div>
                          <span class="text-sm font-mono" style={{ color: siteConfig.accentColor }}>
                            0{index + 1}
                          </span>
                          <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mt-1">
                            {project.name}
                          </h3>
                        </div>
                        
                        {/* Multiple Links Section */}
                        <div class="flex gap-2">
                          {project.links && project.links.map((link) => (
                            <a
                              href={link.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium transition-colors hover:bg-gray-700"
                              title={link.label}
                            >
                              <span>{link.label}</span>
                              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                              </svg>
                            </a>
                          ))}
                        </div>
                      </div>

                      <p class="text-base sm:text-lg text-gray-600 leading-relaxed">
                        {project.description}
                      </p>

                      {project.skills && (
                        <div class="flex flex-wrap gap-1.5 sm:gap-2 pt-2">
                          {project.skills.map((skill) => (
                            <span class="px-2.5 sm:px-3 py-1 sm:py-1.5 bg-gray-200 text-gray-700 rounded-md sm:rounded-lg text-xs sm:text-sm font-medium">
                              {skill}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}